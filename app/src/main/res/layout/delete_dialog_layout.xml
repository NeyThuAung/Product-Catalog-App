<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:padding="20dp"
    app:cardCornerRadius="15dp"
    app:cardElevation="0dp">

    <ImageButton
        android:id="@+id/ibDeleteDialogCancel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_margin="10dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/app_name"
        android:padding="5dp"
        android:src="@drawable/ic_close_bottomsheet"
        app:tint="@color/black" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="10dp"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="15dp"
        android:paddingEnd="12dp"
        android:paddingBottom="20dp">

        <ImageView
            android:id="@+id/ivDeleteDialogAlarm"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="center"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_red_delete"
            android:visibility="visible" />

        <TextView
            android:id="@+id/tvDeleteDialogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="15dp"
            android:fontFamily="@font/inter_semibold"
            android:gravity="center"
            android:textColor="@color/text_black_color"
            android:textSize="20sp"
            tools:text="Delete Link?" />

        <TextView
            android:id="@+id/tvDeleteDialogDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="5dp"
            android:fontFamily="@font/inter_medium"
            android:gravity="center"
            android:lineHeight="22dp"
            android:text="Are you sure want to log out?"
            android:textColor="@color/text_grey_color"
            android:textSize="14sp"
            android:visibility="visible" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/mbDeleteDialogCancel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_weight="1"
                android:backgroundTint="@color/white"
                android:paddingVertical="13dp"
                android:text="Cancel"
                android:textAllCaps="false"
                android:textColor="@color/text_dark_grey_color"
                app:cornerRadius="13dp"
                app:strokeColor="@color/text_grey_color"
                app:strokeWidth="0.8dp" />

            <Space
                android:layout_width="10dp"
                android:layout_height="5dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/mbDelete"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_weight="1"
                android:backgroundTint="@color/colorError"
                android:paddingVertical="13dp"
                android:text="Logout"
                android:textAllCaps="false"
                android:textColor="@color/white"
                app:cornerRadius="10dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>


