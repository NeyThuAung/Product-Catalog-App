<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.ProductCatalogApp" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.ProductCatalogApp" parent="Base.Theme.ProductCatalogApp" />


    <style name="ActiveNavigatorStyle">
        <item name="iconTint">@null</item>
    </style>

    <style name="BottomNavigationTextActive" parent="TextAppearance.AppCompat">
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">@font/inter_regular</item>
    </style>

    <style name="BottomNavigationTextInactive" parent="TextAppearance.AppCompat">
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">@font/inter_medium</item>
    </style>

    <style name="TabText" parent="Widget.Design.TabLayout">
        <item name="tabTextAppearance">@style/ProductTabTextAppearance</item>
        <item name="android:textSize">14sp</item>
        <item name="fontFamily">@font/inter_semibold</item>
    </style>

    <style name="ProductTabTextAppearance" parent="@android:style/TextAppearance.Widget.TabWidget">
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">@font/inter_bold</item>
    </style>
</resources>